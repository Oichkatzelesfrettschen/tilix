{
    "name": "tilix",
    "description": "A VTE based terminal emulator for Linux",
    "copyright": "Copyright © 2016, Gerald Nunn",
    "authors": ["Gerald Nunn"],
    "mainSourceFile": "source/app.d",
    "preBuildCommands": ["./scripts/dub/strict-check.sh", "./scripts/dub/prepare-resources.sh"],
    "buildRequirements": ["disallowDeprecations"],
    "dflags-ldc": ["-disable-linker-strip-dead","-link-defaultlib-shared=false"],
    "dependencies": {
        "gtk-d:gtkd": "~>3.11.0",
        "gtk-d:vte": "~>3.11.0",
        "bindbc-opengl": "~>1.1.1",
        "bindbc-loader": "~>1.1.5",
        "bindbc-freetype": "~>1.3.3",
        "bindbc-glfw": "~>1.1.0",
        "bindbc-harfbuzz": {
            "path": "vendor/bindbc-harfbuzz",
            "version": "~>0.2.1"
        },
        "bindbc-fontconfig": "~>1.0.0",
        "arsd-official:terminalemulator": {
            "path": "vendor/arsd-official",
            "version": "~>12.1.0"
        },
        "mir-ion": "~>2.3.5",
        "mir-algorithm": "~>3.22.4",
        "intel-intrinsics": "~>1.13.0",
        "capnproto-dlang": "~>0.1.2",
        "xkbcommon-d": "~>0.5.1",
        "xcb-d": "~>2.1.1",
        "xcb-util-wm-d": "~>0.5.0",
        "wayland-client-d": "~>1.8.90",
        "wayland-scanner-d": "~>1.0.0"
    },
    "subConfigurations": {
        "bindbc-freetype": "dynamic",
        "bindbc-glfw": "static"
    },
    "versions": ["GL_33"],
    "buildTypes": {
        "release": {
        },
        "pure-lto": {
            "dflags-ldc": ["-O3", "-mcpu=native", "-flto=thin"],
            "lflags-ldc": ["-flto=thin"]
        },
        "debug": {
            "debugVersions": ["GC"],
            "dflags": ["-g"]
        },
        "localize": {
            "versions": ["Localize"]
        },
        "i686": {
            "dflags": ["-m32", "-c"]
        }
    },

    "configurations": [
        {
            "name": "default",
            "targetType": "executable",
            "libs-linux": ["X11", "Xrandr", "Xpresent", "Xext"],
            "versions": ["StdLoggerDisableTrace"]
        },
        {
            "name": "trace",
            "targetType": "executable",
            "libs-linux": ["X11", "Xrandr", "Xpresent", "Xext"],
            "debugVersions": ["Destructors"]
        },
        {
            "name": "dynamic",
            "targetType": "executable",
            "libs": ["gtkd-3"],
            "libs-linux": ["X11", "Xrandr", "Xpresent", "Xext"],
            "lflags": ["-defaultlib=libgtkd-3.so"],
            "versions": ["StdLoggerDisableTrace"]
        },
        {
            "name": "install",
            "targetType": "executable",
            "libs-linux": ["X11", "Xrandr", "Xpresent", "Xext"],
            "versions": ["StdLoggerDisableTrace"],
            "postBuildCommands": ["./install.sh"]
        },
        {
            "name": "uninstall",
            "targetType": "none",
            "preBuildCommands": ["./uninstall.sh"]
        },
        {
            "name": "bench-scroll",
            "targetType": "executable",
            "mainSourceFile": "scripts/benchmark_scrolling.d",
            "targetName": "benchmark_scrolling",
            "targetPath": "build/dub/bench"
        },
        {
            "name": "pure-d",
            "targetType": "executable",
            "mainSourceFile": "pured/main.d",
            "targetName": "tilix-pure",
            "targetPath": "build/pure",
            "versions": ["PURE_D_BACKEND", "GL_45", "GLFW_33", "StdLoggerDisableTrace", "with_24_bit_color", "HB_with_freetype", "Have_bindbc_freetype"],
            "libs-linux": ["glfw", "GL", "freetype", "X11"],
            "dflags-ldc": ["-mcpu=native", "-O3"],
            "sourcePaths": ["pured"],
            "importPaths": ["pured"],
            "excludedSourceFiles": ["source/*"]
        },
        {
            "name": "pure-d-nogc",
            "targetType": "executable",
            "mainSourceFile": "pured/main.d",
            "targetName": "tilix-pure-nogc",
            "targetPath": "build/pure",
            "versions": ["PURE_D_BACKEND", "PURE_D_STRICT_NOGC", "GL_45", "GLFW_33", "StdLoggerDisableTrace", "with_24_bit_color", "HB_with_freetype", "Have_bindbc_freetype"],
            "libs-linux": ["glfw", "GL", "freetype", "X11"],
            "dflags-ldc": ["-mcpu=native", "-O3"],
            "sourcePaths": ["pured"],
            "importPaths": ["pured"],
            "excludedSourceFiles": ["source/*"]
        },
        {
            "name": "pure-d-tests",
            "targetType": "executable",
            "mainSourceFile": "scripts/pure-d/headless_tests.d",
            "targetName": "tilix-pure-tests",
            "targetPath": "build/pure",
            "versions": ["PURE_D_BACKEND", "GL_45", "GLFW_33", "StdLoggerDisableTrace", "with_24_bit_color", "HB_with_freetype", "Have_bindbc_freetype"],
            "libs-linux": ["glfw", "GL", "freetype", "X11"],
            "sourcePaths": ["scripts/pure-d", "pured"],
            "importPaths": ["scripts/pure-d", "pured"],
            "excludedSourceFiles": ["source/*", "scripts/pure-d/ipc_client.d"]
        },
        {
            "name": "pure-d-search-bench",
            "targetType": "executable",
            "mainSourceFile": "scripts/pure-d/bench_scrollback_search.d",
            "targetName": "tilix-search-bench",
            "targetPath": "build/pure",
            "versions": ["PURE_D_BACKEND", "StdLoggerDisableTrace"],
            "sourcePaths": ["scripts/pure-d", "pured/terminal"],
            "importPaths": ["scripts/pure-d", "pured"],
            "excludedSourceFiles": ["source/*", "scripts/pure-d/ipc_client.d"]
        },
        {
            "name": "ipc-client",
            "targetType": "executable",
            "mainSourceFile": "scripts/pure-d/ipc_client.d",
            "targetName": "tilix-ipc-client",
            "targetPath": "build/pure",
            "versions": ["PURE_D_BACKEND"],
            "sourcePaths": ["scripts/pure-d"],
            "importPaths": ["pured", "scripts/pure-d"],
            "sourceFiles": ["pured/ipc/tilix_capnp.d"],
            "excludedSourceFiles": ["source/*"]
        }
    ]
}

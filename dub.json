{
    "name": "tilix",
    "description": "A VTE based terminal emulator for Linux",
    "copyright": "Copyright © 2016, Gerald Nunn",
    "authors": ["Gerald Nunn"],
    "mainSourceFile": "source/app.d",
    "preBuildCommands": ["./scripts/dub/strict-check.sh", "./scripts/dub/prepare-resources.sh"],
    "buildRequirements": ["disallowDeprecations"],
    "dflags-ldc": ["-disable-linker-strip-dead","-link-defaultlib-shared=false"],
    "dependencies": {
        "gtk-d:gtkd": "~>3.11.0",
        "gtk-d:vte": "~>3.11.0",
        "bindbc-opengl": "~>1.1.1",
        "bindbc-loader": "~>1.1.5",
        "bindbc-freetype": "~>1.3.3",
        "bindbc-glfw": "~>1.1.0",
        "arsd-official:terminalemulator": "~>12.1.0",
        "mir-algorithm": "~>3.21.0",
        "intel-intrinsics": "~>1.13.0"
    },
    "subConfigurations": {
        "bindbc-freetype": "dynamic",
        "bindbc-glfw": "static"
    },
    "versions": ["GL_33"],
    "buildTypes": {
        "release": {
        },
        "debug": {
            "debugVersions": ["GC"],
            "dflags": ["-g"]
        },
        "localize": {
            "versions": ["Localize"]
        },
        "i686": {
            "dflags": ["-m32", "-c"]
        }
    },

    "configurations": [
        {
            "name": "default",
            "targetType": "executable",
            "libs-linux": ["X11", "Xrandr", "Xpresent", "Xext"],
            "versions": ["StdLoggerDisableTrace"]
        },
        {
            "name": "trace",
            "targetType": "executable",
            "libs-linux": ["X11", "Xrandr", "Xpresent", "Xext"],
            "debugVersions": ["Destructors"]
        },
        {
            "name": "dynamic",
            "targetType": "executable",
            "libs": ["gtkd-3"],
            "libs-linux": ["X11", "Xrandr", "Xpresent", "Xext"],
            "lflags": ["-defaultlib=libgtkd-3.so"],
            "versions": ["StdLoggerDisableTrace"]
        },
        {
            "name": "install",
            "targetType": "executable",
            "libs-linux": ["X11", "Xrandr", "Xpresent", "Xext"],
            "versions": ["StdLoggerDisableTrace"],
            "postBuildCommands": ["./install.sh"]
        },
        {
            "name": "uninstall",
            "targetType": "none",
            "preBuildCommands": ["./uninstall.sh"]
        },
        {
            "name": "bench-scroll",
            "targetType": "executable",
            "mainSourceFile": "scripts/benchmark_scrolling.d",
            "targetName": "benchmark_scrolling",
            "targetPath": "build/dub/bench"
        },
        {
            "name": "pure-d",
            "targetType": "executable",
            "mainSourceFile": "pured/main.d",
            "targetName": "tilix-pure",
            "targetPath": "build/pure",
            "versions": ["PURE_D_BACKEND", "GL_45", "StdLoggerDisableTrace"],
            "libs-linux": ["glfw", "GL", "freetype", "X11"],
            "dflags-ldc": ["-mcpu=native", "-O3"],
            "sourcePaths": ["pured"],
            "importPaths": ["pured"],
            "excludedSourceFiles": ["source/*"]
        }
    ]
}
